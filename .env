# ── MicroHarness 配置文件 ──────────────────────────────────────────
# 填入你的配置，不要提交到 git（已在 .gitignore 中排除）
#
# 支持的 PROVIDER：
#   anthropic  → Claude 系列
#   openai     → GPT 系列
#   deepseek   → DeepSeek
#   kimi       → Moonshot / Kimi
#   minimax    → MiniMax
#   qwen       → 通义千问（阿里云）
#   glm        → 智谱 GLM
#   xiaomi     → mimo
# ──────────────────────────────────────────────────────────────────

# ── 选择 Provider ──────────────────────────────────────────────────
PROVIDER=xiaomi

# ── Anthropic（PROVIDER=anthropic 时填）───────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── OpenAI 兼容接口（其他所有 provider 共用，中文api）─────────────────────
# DeepSeek : https://api.deepseek.com
# Kimi     : https://api.moonshot.cn/v1
# MiniMax  : https://api.minimax.chat/v1
# Qwen     : https://dashscope.aliyuncs.com/compatible-mode/v1
# GLM      : https://open.bigmodel.cn/api/paas/v4
# OpenAI   : https://api.openai.com/v1
# Xiaomi   : https://api.xiaomimimo.com/v1

OPENAI_COMPATIBLE_API_KEY=xxxxxx
OPENAI_COMPATIBLE_BASE_URL=https://api.xiaomimimo.com/v1

# ── 模型名 ────────────────────────────────────────────────────────
# Anthropic : claude-sonnet-4-20250514 / claude-haiku-4-5-20251001
# DeepSeek  : deepseek-chat / deepseek-reasoner
# Kimi      : kimi-k2.5
# MiniMax   : MiniMax-M2.7 / MiniMax-M2.7-highspeed / MiniMax-M2.5 
# Qwen      : qwen-turbo / qwen-plus / qwen-max
# GLM       : glm-5.1 / glm-5
# OpenAI    : gpt-4o / gpt-5.3-codex / gpt-5.4
# Mimo      : mimo-v2-pro / mimo-v2-flash

MAIN_MODEL=mimo-v2-pro
MEMORY_MODEL=mimo-v2-flash

# ── 其他配置 ──────────────────────────────────────────────────────
MAX_STEPS=10
